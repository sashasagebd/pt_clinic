{
  "version": "0.0.0",
  "main": "electron-dist/main.js",
  "name": "pt_tool",
  "description": "Tool made to help organize and send out intern hours and information",
  "author": "Sasha Bearman-Drummond",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@types/mime-types": "^3.0.1",
    "@types/node": "^25.3.2",
    "electron": "^40.6.1",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "better-sqlite3": "^12.6.2",
    "electron-squirrel-startup": "^1.0.1",
    "googleapis": "^171.4.0",
    "mime-types": "^3.0.2",
    "open": "^11.0.0"
  },
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "build": "npm run build:frontend && npm run copy:frontend && npm run build:electron",
    "build:frontend": "cd ../pt_frontend && npm run build",
    "copy:frontend": "rm -rf ./dist && cp -r ../pt_frontend/dist ./dist",
    "build:electron": "tsc"
  }
}
